# Copy to .env and fill locally. Never commit the real password.
ELEARNING_USERNAME=
ELEARNING_PASSWORD=

# Optional settings
ELEARNING_BASE_URL=https://elearning.fudan.edu.cn
ELEARNING_HEADLESS=true
ELEARNING_DATA_DIR=.data
ELEARNING_REMIND_DAYS=7
ELEARNING_WEBHOOK_URL=

# Safety lock: keep false until submission has been tested and you intentionally enable it.
ELEARNING_SUBMISSION_ENABLED=false
ELEARNING_AGENT_TIMEOUT_SECONDS=1800
ELEARNING_AGENT_MATERIAL_LIMIT=6
ELEARNING_AGENT_MAX_FILE_MB=25
